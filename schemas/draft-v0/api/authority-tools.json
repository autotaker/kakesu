[
  {
    "type": "function",
    "name": "submit_authority_decision",
    "description": "外部Authority principalまたはadapterがEgress Grantまたは恒久Policy Revisionの判断を返す。組み込みAgent用Toolではなく、通信やRule更新を直接実行しない。",
    "parameters": {
      "type": "object",
      "properties": {
        "authority_request_id": { "type": "string" },
        "decision": { "type": "string", "enum": ["approve", "deny"] },
        "rationale": { "type": "string" },
        "timeout_ms": { "type": ["integer", "null"], "minimum": 0 }
      },
      "required": ["authority_request_id", "decision", "rationale", "timeout_ms"],
      "additionalProperties": false
    },
    "strict": true
  },
  {
    "type": "function",
    "name": "submit_task_escalation_decision",
    "description": "Root Authority principalまたはadapterがRoot Task EscalationへContract判断を返す。Egress Grant承認には使用しない。",
    "parameters": {
      "type": "object",
      "properties": {
        "escalation_request_id": { "type": "string" },
        "message": { "type": "string" },
        "contract_patch": {
          "type": ["object", "null"],
          "properties": {
            "objective": { "type": ["string", "null"] },
            "acceptance": { "type": ["string", "null"] },
            "instructions": { "type": ["string", "null"] }
          },
          "required": ["objective", "acceptance", "instructions"],
          "additionalProperties": false
        },
        "terminate": { "type": "boolean" }
      },
      "required": ["escalation_request_id", "message", "contract_patch", "terminate"],
      "additionalProperties": false
    },
    "strict": true
  }
]
