{
  "acceptance_review": {
    "type": "json_schema",
    "name": "acceptance_review_decision",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "decision": { "type": "string", "enum": ["accept", "reject", "insufficient_evidence"] },
        "rationale": { "type": "string" },
        "unmet_acceptance": { "type": "array", "items": { "type": "string" } },
        "required_evidence": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["decision", "rationale", "unmet_acceptance", "required_evidence", "evidence_refs"],
      "additionalProperties": false
    }
  },
  "grant_decision": {
    "type": "json_schema",
    "name": "policy_grant_decision",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "decision": { "type": "string", "enum": ["grant", "deny", "require_authority"] },
        "rationale": { "type": "string" },
        "question": { "type": ["string", "null"] },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["decision", "rationale", "question", "evidence_refs"],
      "additionalProperties": false
    }
  },
  "egress_review": {
    "type": "json_schema",
    "name": "egress_review_finding",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "verdict": { "type": "string", "enum": ["benign", "policy_bypass", "suspicious", "insufficient_evidence"] },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "rationale": { "type": "string" },
        "attempt_ids": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["verdict", "severity", "rationale", "attempt_ids", "evidence_refs"],
      "additionalProperties": false
    }
  },
  "policy_revision_decision": {
    "type": "json_schema",
    "name": "policy_revision_decision",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "decision": { "type": "string", "enum": ["update", "no_change", "require_authority"] },
        "rationale": { "type": "string" },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["decision", "rationale", "evidence_refs"],
      "additionalProperties": false
    }
  }
}
