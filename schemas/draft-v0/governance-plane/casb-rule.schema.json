{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-harness:governance-plane:casb-rule:draft-v0:r1",
  "x-schema-version": "draft-v0", "x-schema-revision": 1, "x-stability": "draft",
  "type": "object",
  "properties": {
    "rule_id": { "$ref": "../common/primitives.schema.json#/$defs/id" },
    "priority": { "type": "integer", "minimum": 0, "maximum": 1000000 },
    "effect": { "enum": ["allow", "deny"] },
    "protocols": { "type": "array", "items": { "enum": ["dns", "https", "tls", "tcp", "udp"] }, "minItems": 1, "maxItems": 5, "uniqueItems": true },
    "fqdn_patterns": { "type": "array", "items": { "type": "string", "maxLength": 253 }, "maxItems": 256, "uniqueItems": true },
    "resolved_ips": { "type": "array", "items": { "oneOf": [{ "type": "string", "format": "ipv4" }, { "type": "string", "format": "ipv6" }] }, "maxItems": 1024, "uniqueItems": true },
    "ports": { "type": "array", "items": { "type": "integer", "minimum": 1, "maximum": 65535 }, "maxItems": 256, "uniqueItems": true },
    "methods": { "type": "array", "items": { "type": "string", "pattern": "^[A-Z]+$", "maxLength": 32 }, "maxItems": 32, "uniqueItems": true },
    "path_patterns": { "type": "array", "items": { "type": "string", "maxLength": 4096 }, "maxItems": 256 },
    "data_classifications": { "type": "array", "items": { "type": "string", "maxLength": 128 }, "maxItems": 128, "uniqueItems": true },
    "credential_scopes": { "type": "array", "items": { "type": "string", "maxLength": 256 }, "maxItems": 256, "uniqueItems": true },
    "max_body_bytes": { "type": ["integer", "null"], "minimum": 0 },
    "expires_at": { "anyOf": [{ "$ref": "../common/primitives.schema.json#/$defs/timestamp" }, { "type": "null" }] },
    "max_uses": { "type": ["integer", "null"], "minimum": 1 },
    "source_ref": { "$ref": "../common/primitives.schema.json#/$defs/ref" }
  },
  "required": ["rule_id", "priority", "effect", "protocols", "fqdn_patterns", "resolved_ips", "ports", "methods", "path_patterns", "data_classifications", "credential_scopes", "max_body_bytes", "expires_at", "max_uses", "source_ref"],
  "additionalProperties": false
}
