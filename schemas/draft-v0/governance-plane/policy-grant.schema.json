{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-harness:governance-plane:policy-grant:draft-v0:r1",
  "x-schema-version": "draft-v0", "x-schema-revision": 1, "x-stability": "draft",
  "type": "object",
  "properties": {
    "grant_id": { "$ref": "../common/primitives.schema.json#/$defs/id" },
    "workspace_id": { "$ref": "../common/primitives.schema.json#/$defs/id" },
    "source_task_id": { "$ref": "../common/primitives.schema.json#/$defs/id" },
    "origin_task_id": { "$ref": "../common/primitives.schema.json#/$defs/id" },
    "delegation_chain_digest": { "$ref": "../common/primitives.schema.json#/$defs/digest" },
    "contract_version": { "type": "integer", "minimum": 1 },
    "source_challenge_id": { "$ref": "../common/primitives.schema.json#/$defs/id" },
    "source_grant_request_id": { "$ref": "../common/primitives.schema.json#/$defs/id" },
    "source_grant_decision_id": { "$ref": "../common/primitives.schema.json#/$defs/id" },
    "source_authority_decision_id": { "anyOf": [{ "$ref": "../common/primitives.schema.json#/$defs/id" }, { "type": "null" }] },
    "binding_digest": { "$ref": "../common/primitives.schema.json#/$defs/digest" },
    "protocol": { "enum": ["dns", "https", "tls", "tcp", "udp"] },
    "resolved_ip": { "oneOf": [{ "type": "string", "format": "ipv4" }, { "type": "string", "format": "ipv6" }, { "type": "null" }] },
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "credential_scope": { "type": ["string", "null"], "maxLength": 256 },
    "max_uses": { "const": 1 },
    "connection_limit": { "type": "integer", "minimum": 1 },
    "byte_limit": { "type": ["integer", "null"], "minimum": 0 },
    "policy_version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["pending_activation", "active", "revoked"] },
    "use_count": { "type": "integer", "minimum": 0, "maximum": 1 },
    "created_at": { "$ref": "../common/primitives.schema.json#/$defs/timestamp" },
    "expires_at": { "$ref": "../common/primitives.schema.json#/$defs/timestamp" },
    "revoked_at": { "anyOf": [{ "$ref": "../common/primitives.schema.json#/$defs/timestamp" }, { "type": "null" }] }
  },
  "required": ["grant_id", "workspace_id", "source_task_id", "origin_task_id", "delegation_chain_digest", "contract_version", "source_challenge_id", "source_grant_request_id", "source_grant_decision_id", "source_authority_decision_id", "binding_digest", "protocol", "resolved_ip", "port", "credential_scope", "max_uses", "connection_limit", "byte_limit", "policy_version", "status", "use_count", "created_at", "expires_at", "revoked_at"],
  "additionalProperties": false
}
