{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:kakesu:common:event-envelope:draft-v0:r1",
  "x-schema-version": "draft-v0",
  "x-schema-revision": 1,
  "x-stability": "draft",
