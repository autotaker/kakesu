{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:kakesu:common:sequence-invariant:draft-v0:r2",
  "x-schema-version": "draft-v0", "x-schema-revision": 2, "x-stability": "draft",
  "type": "object", "additionalProperties": false,
  "required": ["scenario_id", "ordered_message_types", "correlations", "causations"],
  "properties": {
    "scenario_id": { "$ref": "primitives.schema.json#/$defs/id" },
    "ordered_message_types": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
    "correlations": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/correlation" } },
    "causations": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/causation" } }
  },
  "$defs": {
    "correlation": {
      "type": "object", "additionalProperties": false,
      "required": ["left_type", "left_path", "right_type", "right_path"],
      "properties": {
        "left_type": { "type": "string", "minLength": 1 }, "left_path": { "type": "string", "minLength": 1 },
        "right_type": { "type": "string", "minLength": 1 }, "right_path": { "type": "string", "minLength": 1 }
      }
    },
    "causation": {
      "type": "object", "additionalProperties": false,
      "required": ["cause_type", "effect_type"],
      "properties": {
        "cause_type": { "type": "string", "minLength": 1 },
        "effect_type": { "type": "string", "minLength": 1 }
      }
    }
  }
}
