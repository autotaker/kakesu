{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-harness:common:sequence-message:draft-v0:r1",
  "x-schema-version": "draft-v0",
  "x-schema-revision": 1,
  "x-stability": "draft",
  "title": "Executable tabletop sequence message",
  "type": "object",
  "additionalProperties": false,
  "required": ["message_id", "task_id", "workspace_id", "correlation_id", "causation_message_id", "idempotency_key", "entity", "refs", "occurred_at"],
  "properties": {
    "message_id": { "$ref": "primitives.schema.json#/$defs/id" },
    "task_id": { "$ref": "primitives.schema.json#/$defs/id" },
    "workspace_id": { "anyOf": [{ "$ref": "primitives.schema.json#/$defs/id" }, { "type": "null" }] },
    "correlation_id": { "$ref": "primitives.schema.json#/$defs/id" },
    "local_correlation_id": { "anyOf": [{ "$ref": "primitives.schema.json#/$defs/id" }, { "type": "null" }] },
    "causation_message_id": { "anyOf": [{ "$ref": "primitives.schema.json#/$defs/id" }, { "type": "null" }] },
    "idempotency_key": { "type": "string", "minLength": 1, "maxLength": 512 },
    "redelivery_of_message_id": { "anyOf": [{ "$ref": "primitives.schema.json#/$defs/id" }, { "type": "null" }] },
    "delivery_attempt": { "type": "integer", "minimum": 1 },
    "entity": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "id", "from_state", "to_state"],
      "properties": {
        "kind": { "type": "string", "minLength": 1, "maxLength": 128 },
        "id": { "$ref": "primitives.schema.json#/$defs/id" },
        "from_state": { "type": ["string", "null"], "maxLength": 128 },
        "to_state": { "type": ["string", "null"], "maxLength": 128 }
      }
    },
    "refs": {
      "type": "object",
      "additionalProperties": { "anyOf": [{ "$ref": "primitives.schema.json#/$defs/id" }, { "$ref": "primitives.schema.json#/$defs/ref" }, { "$ref": "primitives.schema.json#/$defs/digest" }, { "type": "integer" }, { "type": "null" }] }
    },
    "occurred_at": { "$ref": "primitives.schema.json#/$defs/timestamp" }
  }
}
