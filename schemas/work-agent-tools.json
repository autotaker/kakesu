  {
    "type": "function",
    "name": "complete_candidate",
    "description": "OwnerがTaskの完了候補を提出し、軽量Acceptance Reviewを開始する。",
    "parameters": {
      "type": "object",
      "properties": {
        "owner_judgement": {
          "type": "string"
        },
        "outcome_ref": {
          "type": "string"
        },
        "artifact_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_refs": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "contract_version": {
          "type": "integer",
          "minimum": 1
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "同期的に待つ上限。超過後も処理は継続し、async_idを返す。"
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ],
          "description": "同一Task・同一Tool内の冪等キー。"
        }
      },
      "required": [
        "owner_judgement",
        "outcome_ref",
        "artifact_refs",
        "evidence_refs",
        "contract_version",
        "timeout_ms",
        "idempotency_key"
      ],
      "additionalProperties": false
    },
    "strict": true
  },
  {
    "type": "function",
    "name": "update_progress",
    "description": "Harnessが定期Maintenance Responseで強制し、Task Progress Ledgerを更新する。通常Actionとしての自発呼出しには依存しない。",
    "parameters": {
      "type": "object",
      "properties": {
        "based_on_progress_version": {
          "type": "integer",
          "minimum": 0
        },
        "through_task_event_sequence": {
          "type": "integer",
          "minimum": 0
        },
        "through_agent_run_event_sequence": {
          "type": "integer",
          "minimum": 0
        },
        "current_focus_id": {
          "type": ["string", "null"]
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "item_id": { "type": "string" },
              "description": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["pending", "in_progress", "completed", "blocked", "cancelled"]
              },
              "evidence_refs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "blocker": {
                "type": ["string", "null"]
              }
            },
            "required": ["item_id", "description", "status", "evidence_refs", "blocker"],
            "additionalProperties": false
          }
        }
      },
      "required": ["based_on_progress_version", "through_task_event_sequence", "through_agent_run_event_sequence", "current_focus_id", "items"],
      "additionalProperties": false
    },
    "strict": true
  },
  {
    "type": "function",
    "name": "cancel_child_task",
    "description": "現在Taskの直接の子Taskへキャンセル要求を出す。",
    "parameters": {
      "type": "object",
      "properties": {
        "child_task_id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "cancellation_policy": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "cascade",
                "detach_children",
                "transfer_children"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "同期的に待つ上限。超過後も処理は継続し、async_idを返す。"
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ],
          "description": "同一Task・同一Tool内の冪等キー。"
        }
      },
      "required": [
        "child_task_id",
        "reason",
        "cancellation_policy",
        "timeout_ms",
        "idempotency_key"
      ],
      "additionalProperties": false
    },
    "strict": true
  },
