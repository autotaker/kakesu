  {
    "type": "function",
    "name": "await_async",
    "description": "既存async operationの完了条件を待つ。期限超過時はpending状態を返し、新しいasync operationは作らない。",
    "parameters": {
      "type": "object",
      "properties": {
        "async_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "all",
            "any"
          ]
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "同期的に待つ上限。超過後も処理は継続し、async_idを返す。"
        }
      },
      "required": [
        "async_ids",
        "mode",
        "timeout_ms"
      ],
      "additionalProperties": false
    },
    "strict": true
  },
