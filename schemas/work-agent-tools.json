[
  {
    "type": "function",
    "name": "terminal",
    "description": "Sandbox内でコマンドを実行する。Sandbox外への直接通信やCredential利用はできない。",
    "parameters": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string"
        },
        "cwd": {
          "type": [
            "string",
            "null"
          ]
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "同期的に待つ上限。超過後も処理は継続し、async_idを返す。"
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ],
          "description": "同一Task・同一Tool内の冪等キー。"
        }
      },
      "required": [
        "command",
        "cwd",
        "timeout_ms",
        "idempotency_key"
      ],
      "additionalProperties": false
    },
    "strict": true
  },
  {
    "type": "function",
    "name": "delegate",
    "description": "独立したObjectiveとAcceptanceを持つ子Task Proposalを提出する。",
    "parameters": {
      "type": "object",
      "properties": {
        "objective": {
          "type": "string"
        },
        "acceptance": {
          "type": "string"
        },
        "instructions": {
          "type": [
            "string",
            "null"
          ]
        },
        "owner_profile": {
          "type": "string",
          "enum": [
            "L1",
            "L2",
            "L3"
          ]
        },
        "workspace_mode": {
          "type": "string",
          "enum": [
            "fork",
            "shared_readonly",
            "empty"
          ]
        },
        "dependency": {
          "type": "string",
          "enum": [
            "required",
            "optional"
          ]
        },
        "artifact_refs": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "同期的に待つ上限。超過後も処理は継続し、async_idを返す。"
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ],
          "description": "同一Task・同一Tool内の冪等キー。"
        }
      },
      "required": [
        "objective",
        "acceptance",
        "instructions",
        "owner_profile",
        "workspace_mode",
        "dependency",
        "artifact_refs",
        "timeout_ms",
        "idempotency_key"
      ],
      "additionalProperties": false
    },
    "strict": true
  },
  {
    "type": "function",
    "name": "ask_parent",
    "description": "Child Owner Agentが判断責任を保持したままParent Owner Agentへ助言を求めるAgent間コミュニケーション。Task Contractは変更しない。",
    "parameters": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string"
        },
        "artifact_refs": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "同期的に待つ上限。超過後も処理は継続し、async_idを返す。"
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ],
          "description": "同一Task・同一Tool内の冪等キー。"
        }
      },
      "required": [
        "message",
        "artifact_refs",
        "timeout_ms",
        "idempotency_key"
      ],
      "additionalProperties": false
    },
    "strict": true
  },
  {
    "type": "function",
    "name": "escalate",
    "description": "Objective・Acceptance・優先順位などTask Contract上の判断責任を上位Authorityへ移す。Child TaskはParent Taskへ、Root Taskは人間のRoot Authorityへ配送する。External Effect承認には使わない。",
    "parameters": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string"
        },
        "artifact_refs": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "同期的に待つ上限。超過後も処理は継続し、async_idを返す。"
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ],
          "description": "同一Task・同一Tool内の冪等キー。"
        }
      },
      "required": [
        "message",
        "artifact_refs",
        "timeout_ms",
        "idempotency_key"
      ],
      "additionalProperties": false
    },
    "strict": true
  },
  {
    "type": "function",
    "name": "reply_to_child",
    "description": "Parent Ownerが子へ応答する。Askにはadvice、Escalationにはcontract_decisionを使う。",
    "parameters": {
      "type": "object",
      "properties": {
        "request_id": {
          "type": "string"
        },
        "response_kind": {
          "type": "string",
          "enum": [
            "advice",
            "contract_decision"
          ]
        },
        "message": {
          "type": "string"
        },
        "contract_patch": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "objective": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "acceptance": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "instructions": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "required": [
                "objective",
                "acceptance",
                "instructions"
              ],
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ]
        },
        "terminate": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "同期的に待つ上限。超過後も処理は継続し、async_idを返す。"
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ],
          "description": "同一Task・同一Tool内の冪等キー。"
        }
      },
      "required": [
        "request_id",
        "response_kind",
        "message",
        "contract_patch",
        "terminate",
        "timeout_ms",
        "idempotency_key"
      ],
      "additionalProperties": false
    },
    "strict": true
  },
