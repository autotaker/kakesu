[
  {
    "type": "function",
    "name": "submit_acceptance_review",
    "description": "Completion Candidateが元のAcceptanceを満たすか軽量評価した結果を確定する。",
    "parameters": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string"
        },
        "candidate_version": {
          "type": "integer",
          "minimum": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "accept",
            "reject",
            "insufficient_evidence"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "unmet_acceptance": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "同期的に待つ上限。超過時はsubmit operationのasync_idを返す。"
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "task_id",
        "candidate_version",
        "decision",
        "rationale",
        "unmet_acceptance",
        "required_evidence",
        "timeout_ms",
        "idempotency_key"
      ],
      "additionalProperties": false
    },
    "strict": true
  },
  {
    "type": "function",
    "name": "submit_policy_decision",
    "description": "正規化EffectをPolicy Cascadeに照らして評価した結果を確定する。",
    "parameters": {
      "type": "object",
      "properties": {
        "effect_id": {
          "type": "string"
        },
        "decision": {
          "type": "string",
          "enum": [
            "allow",
            "deny",
            "require_authority",
            "insufficient_information"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "applied_policy_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "authority_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "question": {
          "type": [
            "string",
            "null"
          ]
        },
        "required_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "value"
            ],
            "additionalProperties": false
          }
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "同期的に待つ上限。超過時はsubmit operationのasync_idを返す。"
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "effect_id",
        "decision",
        "rationale",
        "applied_policy_ids",
        "authority_ref",
        "question",
        "required_evidence",
        "conditions",
        "timeout_ms",
        "idempotency_key"
      ],
      "additionalProperties": false
    },
    "strict": true
  },
  {
    "type": "function",
    "name": "submit_authority_decision",
    "description": "Policyが指定したAuthorityとして例外・高リスク判断を確定する。Effectは直接実行しない。",
    "parameters": {
      "type": "object",
      "properties": {
        "authority_request_id": {
          "type": "string"
        },
        "decision": {
          "type": "string",
          "enum": [
            "approve",
            "deny"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "同期的に待つ上限。超過時はsubmit operationのasync_idを返す。"
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "authority_request_id",
        "decision",
        "rationale",
        "conditions",
        "timeout_ms",
        "idempotency_key"
      ],
      "additionalProperties": false
    },
    "strict": true
  }
]
